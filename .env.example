# ============================================================
# KLASTER — Umgebungsvariablen (Vorlage)
# Kopiere diese Datei nach ".env" und trage echte Werte ein.
# Die Datei ".env" ist per .gitignore ausgeschlossen.
# ============================================================

# ── SMTP (NUR serverseitig — gelangt NIE in den Browser) ────────
# Beispiel Gmail:        smtp.gmail.com / Port 465 (SECURE=true) + App-Passwort
# Beispiel Office365:    smtp.office365.com / Port 587 (SECURE=false)
# Beispiel eigener Host: mail.deinedomain.de / Port 587 oder 465
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=dein-smtp-benutzer
SMTP_PASS=dein-smtp-passwort

# ── Absender / Empfänger der Bewerbungen ─────────────────────────
MAIL_FROM="KLASTER <no-reply@deinedomain.de>"
MAIL_TO=du@deinedomain.de
# Optionaler fester Betreff (leer = automatisch "Neue KLASTER-Bewerbung – <Name>")
MAIL_SUBJECT=

# ── Backend ──────────────────────────────────────────────────────
SERVER_PORT=3001
# CORS: leer lassen für Dev (Proxy). In Produktion z. B. https://klaster.de
ALLOWED_ORIGIN=

# ── Frontend (wird im Browser sichtbar — KEINE Geheimnisse!) ─────
# Leer = Same-Origin (über Vite-Proxy in Dev). In Produktion z. B. https://api.klaster.de
VITE_API_BASE=
