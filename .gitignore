# ===========================================================
# KLASTER — .gitignore
# ===========================================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js
.npm
.yarn/*
.pnpm-store/

# --- Build output / caches ---
dist/
dist-ssr/
build/
.cache/
.temp/
.tmp/
.parcel-cache/
*.tsbuildinfo
.eslintcache
.stylelintcache
coverage/
*.local

# --- Environment / secrets (NEVER commit real SMTP credentials) ---
.env
.env.*
!.env.example

# --- Vercel ---
.vercel/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Editors / IDEs / tooling ---
.claude/
.vscode/*
!.vscode/extensions.json
.idea/
.fleet/
.history/
*.swp
*.swo
*~

# --- OS junk ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
